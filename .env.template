# LinkApp Environment Variables Template
# Copy this file to .env and fill in your actual values

# App Environment
EXPO_PUBLIC_APP_ENV=production

# ==============================================
# SUPABASE CONFIGURATION (Required)
# ==============================================
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
EXPO_PUBLIC_SUPABASE_URL=https://alyrtfczemrahupffrbe.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY


# ==============================================
# GOOGLE SERVICES (Required for Maps)
# ==============================================
# Get from Google Cloud Console: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_GOOGLE_WEB_CLIENT_ID.apps.googleusercontent.com

# ==============================================
# FIREBASE CONFIGURATION (Required for notifications)
# ==============================================
# Get from Firebase Console: https://console.firebase.google.com/
FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789000
FIREBASE_APP_ID=1:123456789000:android:abcdef123456
FCM_SERVER_KEY=YOUR_FCM_SERVER_KEY

# ==============================================
# STREAM CHAT CONFIGURATION (Required for chat/video calls)
# ==============================================
# Get from GetStream.io dashboard: https://dashboard.getstream.io/
EXPO_PUBLIC_STREAM_CHAT_API_KEY=YOUR_STREAM_API_KEY
STREAM_CHAT_SECRET=YOUR_STREAM_SECRET


# ==============================================
# API CONFIGURATION
# ==============================================
# Your backend API base URL
EXPO_PUBLIC_API_BASE_URL=https://your-api-domain.com/api
EXPO_PUBLIC_PAYMENT_API_KEY=YOUR_PAYMENT_API_KEY

# ==============================================
# NOTIFICATION CONFIGURATIONbranch
# ==============================================
# Options: 'firebase', 'expo', 'minimal', 'disabled'
EXPO_PUBLIC_NOTIFICATIONS_MODE=firebase
EXPO_PUBLIC_NOTIFICATIONS_DISABLED=0

# ==============================================
# ANALYTICS (Optional)
# ==============================================
ANALYTICS_ENABLED=true

# ==============================================
# BUILD CONFIGURATION
# ==============================================
JAVA_VERSION=17
NODE_VERSION=20.19.5
NODE_OPTIONS=--max-old-space-size=4096

# ==============================================
# DEVELOPMENT/DEBUGGING (Optional)
# ==============================================
DEBUG_MODE=false
LOG_LEVEL=info