# .easignore

# Android build artifacts
android/.gradle
android/.idea
android/app/build
android/app/.cxx
android/build
android/local.properties

# iOS build artifacts
ios/Pods
ios/build
ios/*.xcworkspace
ios/*.xcuserdata

# Node modules that shouldn't be in the build
node_modules/.cache
node_modules/.bin

# Development files
.expo
.expo-shared

# Version control
.git
.svn

# IDE files
.idea
.vscode
*.iml

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage
.nyc_output

# Temporary files
*.tmp
*.temp
.env.local
.env.development.local
.env.test.local
.env.production.local

# Documentation
docs
*.md
LICENSE

# Build outputs
dist
build
out

# Large media files that aren't needed for build
*.mp4
*.mov
*.avi