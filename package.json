{
  "name": "linkapp",
  "version": "1.0.2",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "dev": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "start:prod": "expo start --no-dev --minify",
    "verify:deployment": "node scripts/verifyDeployment.js",
    "build:preview": "eas build --platform all --profile preview",
    "build:dev": "eas build --platform all --profile development",
    "build:dev:android": "eas build --platform android --profile development",
    "build:dev:android:local": "eas build --platform android --profile development --local",
    "build:dev:ios": "eas build --platform ios --profile development",
    "build:android": "expo build:android --release-channel production",
    "build:ios": "expo build:ios --release-channel production",
    "build:all": "npm run validate:production && eas build --platform all --profile production",
    "build:production:android": "npm run validate:production && eas build --platform android --profile production",
    "build:production:ios": "npm run validate:production && eas build --platform ios --profile production",
    "build:playstore": "eas build --platform android --profile playstore",
    "build:playstore:apk": "eas build --platform android --profile playstore-apk",
    "build:playstore:local": "eas build --platform android --profile playstore --local",
    "submit:android": "eas submit --platform android --profile production",
    "submit:playstore": "eas submit --platform android --profile playstore",
    "submit:ios": "eas submit --platform ios --profile production",
    "validate:production": "node scripts/validate-production-build.js",
    "update:production": "eas update --channel production --environment production",
    "update:preview": "eas update --channel preview",
    "build:testing": "node scripts/build-testing.js",
    "build:testing:android": "eas build --platform android --profile testing",
    "build:standalone-test": "eas build --platform android --profile standalone-test",
    "build:local-server": "eas build --platform android --profile local-server",
    "deploy:production": "node scripts/deploy-production.js",
    "setup:env": "node scripts/setup-env-vars.js",
    "verify:build": "node scripts/verify-production-build.js",
    "verify:webhook": "node scripts/verify-paystack-webhook.js",
    "checklist:deployment": "node scripts/final-deployment-checklist.js",
    "generate:privacy-policy": "node scripts/generate-privacy-policy.js",
    "verify:production": "npx tsx scripts/verify-production-readiness.ts",
    "verify:google-auth:production": "node scripts/verify-google-auth-production.js",
    "create:reviewer-account": "npx tsx scripts/createPlayStoreReviewerAccount.ts",
    "doctor": "expo doctor",
    "install:clean": "rm -rf node_modules && npm cache clean --force && npm install",
    "prebuild": "expo prebuild --clean",
    "prebuild:android": "expo prebuild --platform android --clean",
    "prebuild:ios": "expo prebuild --platform ios --clean",
    "build:web": "expo build:web",
    "optimize": "node scripts/prepareForDeployment.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:services:filtering": "jest __tests__/services/ServicesCategoryFiltering.test.ts",
    "test:services:filtering:verbose": "jest __tests__/services/ServicesCategoryFiltering.test.ts --verbose",
    "test:services:report": "npx tsx scripts/generateTestReport.ts",
    "test:phone": "jest -c jest.unit.config.ts --runTestsByPath utils/__tests__/phone.test.ts",
    "test:auth": "jest __tests__/screens/auth",
    "test:ui": "jest __tests__/components/ThemedComponents.test.tsx",
    "test:new": "jest __tests__/screens/auth __tests__/components/ThemedComponents.test.tsx",
    "test:prod": "NODE_ENV=production jest --coverage",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "type-check": "tsc --noEmit",
    "generate-types": "npx supabase gen types typescript --project-id uceoannpoqbzuncaswqx --schema public > types/supabase.ts",
    "verify:notifications": "node scripts/verify-dependencies.js",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@config-plugins/react-native-webrtc": "^13.0.0",
    "@expo/config-plugins": "^54.0.4",
    "@expo/metro-runtime": "~6.1.2",
